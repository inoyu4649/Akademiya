# GMCAuto 3 (v3.0) 환경변수 설정 파일
# 이 파일을 복사하여 .env로 이름을 변경하고 실제 값으로 채워주세요.

# ── GMCAuto MySQL DB (Akademiya DB와 분리) ────────────────────────
# GMCAuto 3은 2학기 전환과 함께 새 DB(gmcauto3)를 사용한다.
# 기존 gmcauto(v2) DB는 최초 1회 마이그레이션(scripts/migrate-legacy-2026-06-17.ts)의
# 읽기 전용 소스로만 사용되며 별도 LEGACY_GMC_DB_* 값으로 접속한다.
GMC_DB_HOST=mysql                 # Docker Compose 환경: mysql 서비스명 사용
GMC_DB_PORT=3306
GMC_DB_USER=gmcauto
GMC_DB_PASSWORD=your_gmcauto_db_password_here
GMC_DB_NAME=gmcauto3

# ── 레거시 GMCAuto 2 DB (마이그레이션 스크립트 전용, 읽기 전용) ─────
LEGACY_GMC_DB_HOST=mysql
LEGACY_GMC_DB_PORT=3306
LEGACY_GMC_DB_USER=gmcauto
LEGACY_GMC_DB_PASSWORD=your_gmcauto_db_password_here
LEGACY_GMC_DB_NAME=gmcauto

# ── GMCAuto 공개 API (서버-서버 전용, X-Api-Key 헤더) ──────────────
GMC_PUBLIC_API_KEY=

# ── Akademiya API (서버-서버 호출) ────────────────────────────────
# 컨테이너 내부 통신이면 http://backend:3000/api (docker network)
# 외부 접근이면 https://akademiya.kr/api
AKADEMIYA_API_URL=http://backend:3000/api

# ── Akademiya OpenOAuth ("Akademiya로 로그인") ────────────────────
# Akademiya 개발자 도구 → OAuth App에서 GMCAuto용 앱을 등록하고 발급받은 값을 입력하세요.
# (신뢰 오리진에 https://gmc.akademiya.kr 등록 필요, 로그인 허용 범위: HAFS 조직 권장)
AKADEMIYA_OAUTH_CLIENT_ID=
AKADEMIYA_OAUTH_CLIENT_SECRET=
AKADEMIYA_OAUTH_AUTHORIZE_URL=https://akademiya.kr/oauth/authorize
AKADEMIYA_OAUTH_REDIRECT_URI=https://gmc.akademiya.kr/auth/callback

# ── 서버 설정 ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── 푸시 알림 VAPID 키 (Web Push) ───────────────────────────────
# 미설정 시 첫 실행 때 자동 생성 후 .vapid_keys.json에 저장됩니다.
# 안정적인 운영을 위해 아래 명령으로 생성 후 직접 설정을 권장합니다:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:022207@hafs.hs.kr
