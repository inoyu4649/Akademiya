{
  "name": "akashaalt",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AkashaAlt(ai.akademiya.kr) — Akademiya 계정과 완전히 독립된 AI 채팅 WebApp (GMCAuto와 동일한 프론트+백엔드 단일 앱 구조)",
  "scripts": {
    "dev": "vite --host",
    "server": "tsx server/index.ts",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "prod": "npm run build && tsx server/index.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "nodemailer": "^9.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.19.2",
    "uuid": "^11.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.12.4",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "typescript": "~6.0.3",
    "vite": "8.0.16"
  }
}
