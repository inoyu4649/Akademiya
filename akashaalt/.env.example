# ──────────────────────────────────────────────────────────────────────────────
#  akashaalt 환경변수 템플릿
#  이 파일을 복사하여 .env를 만들고 실제 값을 채워주세요.
#  주의: .env는 절대 git에 커밋하지 마세요!
# ──────────────────────────────────────────────────────────────────────────────

PORT=3003
NODE_ENV=production

# ── 자체 MySQL 스키마 (Akademiya 본체 DB와 완전히 분리, GMCAuto의 gmcauto 스키마와 동일 구조) ──
AKASHAALT_DB_HOST=mysql
AKASHAALT_DB_PORT=3306
AKASHAALT_DB_USER=akademiya
AKASHAALT_DB_PASSWORD=
AKASHAALT_DB_NAME=akashaalt

# ── 자체 세션 토큰 서명 키 (Akademiya JWT와 무관 — 반드시 32자 이상 무작위 문자열로 변경) ──
AKASHAALT_JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_JWT_SECRET

# ── Akademiya OpenOAuth 서드파티 클라이언트 ────────────────────────────────────
# Akademiya 개발자 도구(개발자 모드 → OAuth App)에서 "AkashaAlt" 앱을 등록한 뒤
# 발급받은 Client ID/Secret. 신뢰 출처(origins)에 https://ai.akademiya.kr 등록 필요.
AKADEMIYA_API_URL=http://backend:3000/api
AI_OAUTH_CLIENT_ID=
AI_OAUTH_CLIENT_SECRET=
AI_OAUTH_AUTHORIZE_URL=https://akademiya.kr/oauth/authorize
AI_OAUTH_REDIRECT_URI=https://ai.akademiya.kr/auth/callback

# ── 이메일 (API Key Vault 비밀번호 변경/초기화 인증코드 발송) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AkashaAlt <noreply@akademiya.kr>
