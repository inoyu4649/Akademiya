# ──────────────────────────────────────────────────────────────────────────────
#  Akademiya Backend 환경변수 템플릿
#  이 파일을 복사하여 .env를 만들고 실제 값을 채워주세요.
#  주의: .env는 절대 git에 커밋하지 마세요!
# ──────────────────────────────────────────────────────────────────────────────

# ── 서버 ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # production | development
FRONTEND_URL=http://localhost:5173   # 프로덕션: https://akademiya.kr

# ── OCI MySQL 데이터베이스 ──────────────────────────────────────────────────────
DB_HOST=localhost             # 프로덕션: OCI MySQL 호스트 주소
DB_PORT=3306
DB_USER=akademiya
DB_PASSWORD=your_db_password
DB_NAME=akademiya
# 프로덕션에서는 NODE_ENV=production 이면 SSL 자동 활성화 (pool.ts 참고)

# ── JWT 시크릿 (반드시 32자 이상 무작위 문자열로 변경) ─────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_32_CHARS_MINIMUM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MINIMUM_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# 프로덕션: https://akademiya.kr/api/auth/google/callback

# ── 이메일 (SMTP / Gmail App Password) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password   # Gmail 앱 비밀번호 (2단계 인증 필요)
EMAIL_FROM=Akademiya <noreply@akademiya.kr>
